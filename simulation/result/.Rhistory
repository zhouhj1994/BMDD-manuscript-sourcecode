file.bmdd.saver <- function(m, n, q, q1, p, p1, r) {
file <- paste0('bmdd_saver_m_', m, '_n_', n, '_q_', q,
'_q1_', q1, '_p_', p, '_p1_', p1, '_r_', r, '/')
return(file)
}
file.cov <- function(m, n, q, q1, p, p1, r) {
file <- paste0('cov_m_', m, '_n_', n, '_q_', q,
'_q1_', q1, '_p_', p, '_p1_', p1, '_r_', r, '/')
return(file)
}
file <- function(m, n, q, q1, p, p1, r) {
file <- paste0('m_', m, '_n_', n, '_q_', q,
'_q1_', q1, '_p_', p, '_p1_', p1, '_r_', r, '/')
return(file)
}
file.mbDenoise.mbImpute <- function(name, s) {
file <- paste0(name, '_simulation', s, '/')
return(file)
}
file.nonpara <- function(name, q, q1, r) {
file <- paste0('nonpara_', name, '_m_', n, '_n_', n, '_q_', q, '_q1_', q1, '_r_', r, '/')
return(file)
}
