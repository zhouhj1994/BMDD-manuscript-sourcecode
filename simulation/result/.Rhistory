library(foreach)
nsim <- 20
fun <- function(file) {
output.raw <- foreach (ii = 1 : nsim, .combine = 'rbind') %do% {
as.vector(unlist(read.table(paste0(file, '/', ii, ".txt"))))
}
res <- output.raw
est <- colMeans(res, na.rm = TRUE)
num.nan <- colSums(matrix(!is.na(res), nrow = nsim))
est.sd <- sqrt(rowSums((t(res) - est) ^ 2, na.rm = TRUE) / ((num.nan - 1) * num.nan))
output <- c(est,est.sd)
write.table(output, paste0('output_', file, '.txt'))
}
